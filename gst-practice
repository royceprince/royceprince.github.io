<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CA Inter GST Flashcard Pro 2026 | ICAI Exam Ready</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap');

:root {
  --bg: #07080f;
  --bg2: #0d0f1a;
  --bg3: #121520;
  --surface: #181c2e;
  --surface2: #1e2338;
  --border: #252a40;
  --border2: #2e3454;
  --text: #e8eaf6;
  --text2: #9ba3c9;
  --text3: #5d6591;
  --accent: #5865f2;
  --accent2: #7289da;
  --gold: #f4c055;
  --green: #43d98e;
  --red: #f04747;
  --orange: #fa8231;
  --purple: #9b59b6;
  --cyan: #4dd0e1;
  --pink: #e91e63;
  --card-front: #131829;
  --card-back: #0e1f14;
  --shadow: 0 8px 32px rgba(0,0,0,0.6);
  --radius: 16px;
  --font: 'Sora', sans-serif;
  --mono: 'JetBrains Mono', monospace;
}
.light {
  --bg: #f0f2f8;
  --bg2: #e8ecf5;
  --bg3: #dde2f0;
  --surface: #ffffff;
  --surface2: #f5f7ff;
  --border: #d0d6ee;
  --border2: #bcc4e4;
  --text: #1a1f3c;
  --text2: #4a5280;
  --text3: #8892b0;
  --card-front: #ffffff;
  --card-back: #f0fff6;
  --shadow: 0 8px 32px rgba(0,0,0,0.12);
}

*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font);background:var(--bg);color:var(--text);min-height:100vh;transition:background .3s,color .3s}

/* ── HEADER ── */
.header{padding:16px 20px;background:var(--bg2);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;position:sticky;top:0;z-index:100;backdrop-filter:blur(12px)}
.logo{display:flex;align-items:center;gap:10px}
.logo-icon{width:36px;height:36px;background:linear-gradient(135deg,var(--accent),var(--purple));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:900;color:#fff;font-family:var(--mono)}
.logo-text h1{font-size:14px;font-weight:800;color:var(--text);letter-spacing:-.3px}
.logo-text p{font-size:10px;color:var(--text3);font-family:var(--mono)}
.header-right{display:flex;align-items:center;gap:8px}
.badge{font-size:9px;font-weight:800;padding:3px 8px;border-radius:20px;letter-spacing:.5px;font-family:var(--mono)}
.badge-green{background:rgba(67,217,142,.15);color:var(--green);border:1px solid rgba(67,217,142,.3)}
.badge-gold{background:rgba(244,192,85,.15);color:var(--gold);border:1px solid rgba(244,192,85,.3)}
.badge-blue{background:rgba(88,101,242,.15);color:var(--accent2);border:1px solid rgba(88,101,242,.3)}
.icon-btn{width:34px;height:34px;border-radius:10px;border:1px solid var(--border);background:var(--surface);color:var(--text2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;transition:all .2s}
.icon-btn:hover{border-color:var(--accent);color:var(--accent)}

/* ── TABS ── */
.tabs-wrapper{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 20px}
.mode-tabs{display:flex;gap:0}
.mode-tab{padding:12px 18px;font-size:11px;font-weight:700;color:var(--text3);cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap;font-family:var(--mono);letter-spacing:.5px}
.mode-tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.mode-tab:hover:not(.active){color:var(--text2)}

/* ── MAIN LAYOUT ── */
.main{max-width:900px;margin:0 auto;padding:20px 16px}

/* ── CHAPTER FILTER ── */
.chapter-bar{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:16px;padding:12px;background:var(--surface);border-radius:var(--radius);border:1px solid var(--border)}
.ch-btn{font-size:9.5px;font-weight:700;padding:4px 9px;border-radius:8px;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--text3);transition:all .15s;font-family:var(--mono)}
.ch-btn:hover{border-color:var(--accent2);color:var(--text2)}
.ch-btn.active{background:var(--accent);border-color:var(--accent);color:#fff}

/* ── CATEGORY PILLS ── */
.pill-bar{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:14px}
.pill{font-size:9px;font-weight:700;padding:4px 10px;border-radius:20px;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--text3);transition:all .15s;font-family:var(--mono);letter-spacing:.3px}
.pill:hover{color:var(--text)}
.pill.active{color:#fff}
.pill-concept.active{background:rgba(88,101,242,.8);border-color:var(--accent)}
.pill-mcq.active{background:rgba(67,217,142,.8);border-color:var(--green)}
.pill-case.active{background:rgba(250,130,49,.8);border-color:var(--orange)}
.pill-trap.active{background:rgba(240,71,71,.8);border-color:var(--red)}
.pill-pyq.active{background:rgba(155,89,182,.8);border-color:var(--purple)}
.pill-rtp.active{background:rgba(77,208,225,.8);border-color:var(--cyan)}
.pill-mtp.active{background:rgba(244,192,85,.8);border-color:var(--gold)}
.pill-hard.active{background:rgba(233,30,99,.8);border-color:var(--pink)}
.pill-all.active{background:var(--surface2);border-color:var(--border2);color:var(--text)}

/* ── PROGRESS ── */
.progress-row{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.progress-track{flex:1;height:6px;background:var(--surface2);border-radius:3px;overflow:hidden}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--purple));border-radius:3px;transition:width .4s ease}
.progress-text{font-size:11px;font-weight:700;color:var(--text2);font-family:var(--mono);white-space:nowrap}

/* ── DIFFICULTY LEGEND ── */
.diff-row{display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap}
.diff-badge{font-size:9px;font-weight:700;padding:3px 8px;border-radius:20px;font-family:var(--mono)}
.diff-easy{background:rgba(67,217,142,.1);color:var(--green);border:1px solid rgba(67,217,142,.3)}
.diff-medium{background:rgba(244,192,85,.1);color:var(--gold);border:1px solid rgba(244,192,85,.3)}
.diff-hard{background:rgba(240,71,71,.1);color:var(--red);border:1px solid rgba(240,71,71,.3)}

/* ── FLIP CARD ── */
.card-scene{perspective:1200px;min-height:320px;margin-bottom:16px;cursor:pointer}
.card-wrapper{width:100%;height:100%;position:relative;transform-style:preserve-3d;transition:transform .55s cubic-bezier(.4,.2,.2,1);min-height:320px}
.card-wrapper.flipped{transform:rotateY(180deg)}
.card-face{position:absolute;width:100%;height:100%;backface-visibility:hidden;border-radius:var(--radius);padding:24px;border:1px solid var(--border2);display:flex;flex-direction:column}
.card-front{background:var(--card-front);box-shadow:var(--shadow)}
.card-back{background:var(--card-back);transform:rotateY(180deg);box-shadow:var(--shadow)}
.card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.card-type{font-size:9px;font-weight:800;padding:3px 10px;border-radius:20px;font-family:var(--mono);letter-spacing:.5px}
.card-diff{font-size:9px;font-weight:700;padding:2px 8px;border-radius:12px;font-family:var(--mono)}
.card-body{flex:1;display:flex;flex-direction:column;justify-content:center}
.card-q{font-size:15px;font-weight:700;line-height:1.5;color:var(--text);margin-bottom:14px}
.card-options{display:flex;flex-direction:column;gap:7px}
.card-option{font-size:12px;padding:9px 13px;border-radius:10px;background:var(--surface2);border:1px solid var(--border);color:var(--text2);line-height:1.4;transition:all .2s;font-weight:500}
.card-option:hover{border-color:var(--accent2);color:var(--text)}
.card-option.correct{background:rgba(67,217,142,.12);border-color:var(--green);color:var(--green)}
.card-option.wrong{background:rgba(240,71,71,.1);border-color:var(--red);color:var(--red)}
.card-hint{font-size:10px;color:var(--text3);font-family:var(--mono);text-align:center;margin-top:10px}
/* Back face */
.card-ans-label{font-size:9px;font-weight:800;color:var(--green);font-family:var(--mono);letter-spacing:1px;margin-bottom:8px}
.card-ans{font-size:15px;font-weight:700;color:var(--green);margin-bottom:12px;line-height:1.4}
.card-exp{font-size:12px;color:var(--text2);line-height:1.6;background:var(--surface2);border-radius:10px;padding:12px;border-left:3px solid var(--accent)}
.card-trap{font-size:11px;color:var(--orange);background:rgba(250,130,49,.08);border-radius:8px;padding:8px 12px;margin-top:10px;border:1px dashed rgba(250,130,49,.3)}
.card-law{font-size:10px;color:var(--text3);font-family:var(--mono);margin-top:10px}
.flip-hint{font-size:10px;color:var(--text3);text-align:center;margin-top:12px;opacity:.7}

/* ── CONTROLS ── */
.controls{display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:20px;flex-wrap:wrap}
.ctrl-btn{padding:9px 18px;border-radius:10px;font-size:11px;font-weight:700;cursor:pointer;border:1px solid var(--border);background:var(--surface);color:var(--text2);transition:all .2s;font-family:var(--mono);display:flex;align-items:center;gap:6px}
.ctrl-btn:hover{border-color:var(--accent);color:var(--accent)}
.ctrl-btn.primary{background:var(--accent);border-color:var(--accent);color:#fff}
.ctrl-btn.primary:hover{background:#4752c4}
.card-counter{font-size:12px;font-weight:700;color:var(--text2);font-family:var(--mono);min-width:70px;text-align:center}

/* ── SCORE TRACKER ── */
.score-bar{display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap}
.score-item{flex:1;min-width:80px;background:var(--surface);border-radius:10px;border:1px solid var(--border);padding:10px;text-align:center}
.score-num{font-size:22px;font-weight:800;font-family:var(--mono)}
.score-label{font-size:9px;color:var(--text3);font-weight:600;margin-top:2px;font-family:var(--mono)}
.score-green .score-num{color:var(--green)}
.score-red .score-num{color:var(--red)}
.score-gold .score-num{color:var(--gold)}
.score-blue .score-num{color:var(--accent2)}

/*/* ── CASE SCENARIOS ── */
.cs-opt{border-radius:10px;padding:10px 14px;font-size:12px;line-height:1.5;transition:border-color .15s,background .15s;user-select:none}
#cs-search:focus{border-color:var(--accent);outline:none}
#cs-search::placeholder{color:var(--text3)}

/* ── EXAM MODE ── */
.exam-timer{display:flex;align-items:center;gap:12px;background:var(--surface);border-radius:12px;padding:12px 16px;margin-bottom:16px;border:1px solid var(--border)}
.timer-display{font-size:24px;font-weight:800;font-family:var(--mono);color:var(--gold);letter-spacing:2px}
.timer-label{font-size:10px;color:var(--text3);font-family:var(--mono)}
.timer-danger .timer-display{color:var(--red);animation:pulse .8s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
.exam-progress-detail{font-size:11px;color:var(--text2);font-family:var(--mono);margin-left:auto}

/* ── RESULTS PANEL ── */
.results-panel{background:var(--surface);border-radius:var(--radius);border:1px solid var(--border);padding:28px;text-align:center;margin-top:20px}
.results-score{font-size:52px;font-weight:800;font-family:var(--mono);background:linear-gradient(135deg,var(--green),var(--accent));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.results-grade{font-size:18px;font-weight:700;margin:8px 0 16px}
.results-stats{display:flex;justify-content:center;gap:24px;flex-wrap:wrap;margin-bottom:20px}
.results-stat{text-align:center}
.results-stat-num{font-size:24px;font-weight:800;font-family:var(--mono)}
.results-stat-label{font-size:10px;color:var(--text3);font-family:var(--mono)}
.results-breakdown{background:var(--bg2);border-radius:10px;padding:14px;margin-bottom:20px;text-align:left}
.rb-row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border);font-size:11px;font-family:var(--mono)}
.rb-row:last-child{border-bottom:none}

/* ── SECTIONS ── */
.section{display:none}
.section.active{display:block}

/* ── LOADER ── */
.card-loader{display:flex;align-items:center;justify-content:center;min-height:300px;font-size:13px;color:var(--text3);font-family:var(--mono)}

/* ── QUICK REF MINI ── */
.qref-panel{background:var(--surface);border-radius:var(--radius);border:1px solid var(--border);padding:16px;margin-top:16px}
.qref-title{font-size:11px;font-weight:800;color:var(--accent2);font-family:var(--mono);margin-bottom:10px;letter-spacing:.5px}
.qref-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px}
.qref-item{background:var(--bg2);border-radius:8px;padding:8px 10px;border:1px solid var(--border)}
.qref-key{font-size:9px;font-weight:800;color:var(--text3);font-family:var(--mono);margin-bottom:3px}
.qref-val{font-size:11px;font-weight:600;color:var(--text)}

/* ── AMENDMENT BANNER ── */
.amend-banner{background:linear-gradient(135deg,rgba(88,101,242,.12),rgba(155,89,182,.12));border:1px solid rgba(88,101,242,.3);border-radius:10px;padding:10px 14px;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.amend-tag{font-size:9px;font-weight:800;background:var(--accent);color:#fff;padding:2px 8px;border-radius:20px;font-family:var(--mono);white-space:nowrap}
.amend-text{font-size:11px;color:var(--text2);line-height:1.4}

/* ── RESPONSIVE ── */
@media(max-width:640px){
  .main{padding:12px 10px}
  .header{padding:10px 14px}
  .card-q{font-size:13px}
  .card-face{padding:16px}
  .results-score{font-size:40px}
  .mode-tab{padding:10px 12px;font-size:10px}
}

/* ── ANIMATIONS ── */
.card-enter{animation:slideIn .35s ease}
@keyframes slideIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.flash-correct{animation:flashG .5s ease}
.flash-wrong{animation:flashR .5s ease}
@keyframes flashG{0%,100%{box-shadow:var(--shadow)}50%{box-shadow:0 0 30px rgba(67,217,142,.5)}}
@keyframes flashR{0%,100%{box-shadow:var(--shadow)}50%{box-shadow:0 0 30px rgba(240,71,71,.5)}}

/* ── NOTIFICATION ── */
.notif{position:fixed;bottom:20px;right:20px;background:var(--surface);border:1px solid var(--border2);border-radius:12px;padding:12px 18px;font-size:12px;font-weight:600;color:var(--text);box-shadow:var(--shadow);transform:translateY(100px);transition:transform .3s;z-index:999;font-family:var(--mono)}
.notif.show{transform:translateY(0)}

/* ── CHAPTER COLORS ── */
.ch1{--chcol:#5865f2}.ch2{--chcol:#43d98e}.ch3{--chcol:#fa8231}.ch4{--chcol:#f4c055}
.ch5{--chcol:#4dd0e1}.ch6{--chcol:#9b59b6}.ch7{--chcol:#e91e63}.ch8{--chcol:#00bcd4}
.ch9{--chcol:#ff5722}.ch10{--chcol:#8bc34a}.ch11{--chcol:#ffc107}.ch12{--chcol:#03a9f4}
.ch13{--chcol:#e91e63}.ch14{--chcol:#673ab7}
</style>
</head>
<body>

<!-- ═══ HEADER ═══ -->
<div class="header">
  <div class="logo">
    <div class="logo-icon">CA</div>
    <div class="logo-text">
      <h1>GST Flashcard Pro 2026</h1>
      <p>CA INTER · ICAI EXAM READY · 2025 AMENDMENTS</p>
    </div>
  </div>
  <div class="header-right">
    <span class="badge badge-green">350+ Q's</span>
    <span class="badge badge-gold">50 Case Scenarios</span>
    <span class="badge badge-blue">ICAI May 2026</span>
    <button class="icon-btn" id="darkBtn" onclick="toggleDark()" title="Toggle Dark/Light">☀️</button>
  </div>
</div>

<!-- ═══ MODE TABS ═══ -->
<div class="tabs-wrapper">
  <div class="mode-tabs">
    <div class="mode-tab active" onclick="setMode('practice')">📚 Practice Mode</div>
    <div class="mode-tab" onclick="setMode('exam')">⏱ Exam Mode</div>
    <div class="mode-tab" onclick="setMode('case')">📋 Case Scenarios</div>
    <div class="mode-tab" onclick="setMode('results')">📊 My Progress</div>
  </div>
</div>

<div class="main">

<!-- ═══ AMENDMENT BANNER ═══ -->
<div class="amend-banner">
  <span class="amend-tag">🆕 2025</span>
  <span class="amend-text">Finance Act 2025 Amendments Covered: ECO for Composition Dealers (Goods), Sec 5A/5B RCM Entries, Biometric Aadhaar Auth for Registration, GSTR-1A, ISD Mechanism Changes & more</span>
</div>

<!-- ═══ PRACTICE SECTION ═══ -->
<div class="section active" id="sec-practice">

  <!-- Chapter Bar -->
  <div class="chapter-bar">
    <button class="ch-btn active" onclick="filterChapter('ALL')">ALL</button>
    <button class="ch-btn" onclick="filterChapter('CH1')">Ch1 Basics</button>
    <button class="ch-btn" onclick="filterChapter('CH2')">Ch2 Supply</button>
    <button class="ch-btn" onclick="filterChapter('CH3')">Ch3 RCM</button>
    <button class="ch-btn" onclick="filterChapter('CH4')">Ch4 Composition</button>
    <button class="ch-btn" onclick="filterChapter('CH5')">Ch5 POS</button>
    <button class="ch-btn" onclick="filterChapter('CH6')">Ch6 Exempt</button>
    <button class="ch-btn" onclick="filterChapter('CH7')">Ch7 TOS</button>
    <button class="ch-btn" onclick="filterChapter('CH8')">Ch8 VOS</button>
    <button class="ch-btn" onclick="filterChapter('CH9')">Ch9 ITC</button>
    <button class="ch-btn" onclick="filterChapter('CH10')">Ch10 Reg</button>
    <button class="ch-btn" onclick="filterChapter('CH11')">Ch11 Invoice</button>
    <button class="ch-btn" onclick="filterChapter('CH12')">Ch12 Accounts</button>
    <button class="ch-btn" onclick="filterChapter('CH13')">Ch13 Payment</button>
    <button class="ch-btn" onclick="filterChapter('CH14')">Ch14 Returns</button>
  </div>

  <!-- Category Pills -->
  <div class="pill-bar">
    <button class="pill pill-all active" onclick="filterCat('ALL')">🔘 All Types</button>
    <button class="pill pill-concept" onclick="filterCat('CONCEPT')">💡 Concept</button>
    <button class="pill pill-mcq" onclick="filterCat('MCQ')">✅ MCQ</button>
    <button class="pill pill-case" onclick="filterCat('CASE')">📋 Case Study</button>
    <button class="pill pill-trap" onclick="filterCat('TRAP')">⚠️ Trap Q</button>
    <button class="pill pill-pyq" onclick="filterCat('PYQ')">🏛 PYQ</button>
    <button class="pill pill-rtp" onclick="filterCat('RTP')">📘 RTP</button>
    <button class="pill pill-mtp" onclick="filterCat('MTP')">📝 MTP</button>
    <button class="pill pill-hard" onclick="filterCat('HARD')">🔥 PowerAI</button>
  </div>

  <!-- Diff + Progress -->
  <div class="diff-row">
    <span class="diff-badge diff-easy">🟢 Easy</span>
    <span class="diff-badge diff-medium">🟡 Medium</span>
    <span class="diff-badge diff-hard">🔴 Hard</span>
  </div>

  <!-- Score Bar -->
  <div class="score-bar">
    <div class="score-item score-green"><div class="score-num" id="sc-correct">0</div><div class="score-label">CORRECT</div></div>
    <div class="score-item score-red"><div class="score-num" id="sc-wrong">0</div><div class="score-label">WRONG</div></div>
    <div class="score-item score-gold"><div class="score-num" id="sc-skip">0</div><div class="score-label">SKIPPED</div></div>
    <div class="score-item score-blue"><div class="score-num" id="sc-pct">-</div><div class="score-label">ACCURACY</div></div>
  </div>

  <!-- Progress -->
  <div class="progress-row">
    <div class="progress-track"><div class="progress-fill" id="prog-fill" style="width:0%"></div></div>
    <div class="progress-text" id="prog-text">0 / 0</div>
  </div>

  <!-- FLASHCARD -->
  <div class="card-scene" id="card-scene" onclick="flipCard()">
    <div class="card-wrapper" id="card-wrapper">
      <div class="card-face card-front" id="card-front"></div>
      <div class="card-face card-back" id="card-back"></div>
    </div>
  </div>
  <div class="flip-hint">👆 Click card to flip • Use buttons below to navigate</div>

  <!-- Controls -->
  <div class="controls">
    <button class="ctrl-btn" onclick="prevCard()">← Prev</button>
    <span class="card-counter" id="card-counter">1 / 1</span>
    <button class="ctrl-btn primary" onclick="nextCard()">Next →</button>
    <button class="ctrl-btn" onclick="shuffleCards()" title="Shuffle">🔀 Shuffle</button>
    <button class="ctrl-btn" onclick="markCorrect()" title="Mark Correct">✅</button>
    <button class="ctrl-btn" onclick="markWrong()" title="Mark Wrong">❌</button>
  </div>
</div>

<!-- ═══ EXAM SECTION ═══ -->
<div class="section" id="sec-exam">
  <div id="exam-setup">
    <div class="results-panel" style="margin-top:0">
      <div style="font-size:28px;margin-bottom:12px">⏱</div>
      <div style="font-size:20px;font-weight:800;margin-bottom:8px">Exam Mode</div>
