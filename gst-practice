// ─── CS STATE ───────────────────────────────────────────────
let cs = {
  scenarioIdx: 0,   // index into CASE_SCENARIOS
  qIdx: 0,
  answers: [],      // null / index
  answered: false,
  scores: {}        // num -> {c, w, s}
};

// ─── RENDER SCENARIO LIST ────────────────────────────────────
function renderCsGrid(filter) {
  const grid = document.getElementById('cs-grid');
  const q = (filter || '').toLowerCase();
  let html = '';
  CASE_SCENARIOS.forEach((s, i) => {
    const sc = cs.scores[s.num] || {c:0,w:0,s:0};
    const total = s.qs.length;
    const done = sc.c + sc.w + sc.s;
    const pct = done === total && total > 0 ? Math.round(sc.c/total*100) : null;
    if (q && !s.ctx.toLowerCase().includes(q) && !('scenario '+s.num).includes(q)) return;
    const statusColor = pct === null ? 'var(--border)' : pct >= 60 ? 'var(--green)' : 'var(--red)';
    const statusText = pct === null ? (done > 0 ? done+'/'+total+' done' : total+' Q') : pct+'%';
    html += `<div onclick="openScenario(${i})" style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:10px 12px;cursor:pointer;transition:all .2s;border-top:3px solid ${statusColor}" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='${statusColor}'">
      <div style="font-size:9px;font-weight:800;color:var(--accent);font-family:var(--mono);margin-bottom:4px">SCENARIO ${s.num}</div>
      <div style="font-size:10px;color:var(--text2);line-height:1.5;margin-bottom:6px;height:42px;overflow:hidden">${s.ctx.substring(0,70)}...</div>
      <div style="font-size:9px;font-family:var(--mono);color:${statusColor};font-weight:700">${statusText}</div>
    </div>`;
  });
  grid.innerHTML = html || '<div style="color:var(--text3);font-size:12px;text-align:center;padding:24px">No scenarios found</div>';
}

function filterScenarios() {
  renderCsGrid(document.getElementById('cs-search').value);
}

// ─── OPEN SCENARIO ───────────────────────────────────────────
function openScenario(idx) {
  cs.scenarioIdx = idx;
  cs.qIdx = 0;
  cs.answers = new Array(CASE_SCENARIOS[idx].qs.length).fill(null);
  cs.answered = false;
  document.getElementById('cs-list-view').style.display = 'none';
  document.getElementById('cs-scenario-view').style.display = 'block';
  document.getElementById('cs-results').style.display = 'none';
  const s = CASE_SCENARIOS[idx];
  document.getElementById('cs-scenario-label').textContent = 'CASE SCENARIO ' + s.num;
  document.getElementById('cs-context-text').textContent = s.ctx;
  renderCsQ();
}

function showCsList() {
  document.getElementById('cs-list-view').style.display = 'block';
  document.getElementById('cs-scenario-view').style.display = 'none';
  renderCsGrid();
}

// ─── RENDER QUESTION ─────────────────────────────────────────
function renderCsQ() {
  const s = CASE_SCENARIOS[cs.scenarioIdx];
  const total = s.qs.length;
  cs.qIdx = Math.max(0, Math.min(cs.qIdx, total - 1));
  const q = s.qs[cs.qIdx];
  const sel = cs.answers[cs.qIdx];
  const revealed = sel !== null;

  // Progress
  const done = cs.answers.filter(a => a !== null).length;
  document.getElementById('cs-prog-bar').style.width = (done/total*100) + '%';
  document.getElementById('cs-prog-text').textContent = 'Q ' + (cs.qIdx+1) + '/' + total;

  // Score
  let c=0,w=0,sk=0;
  cs.answers.forEach((a,i) => {
    if (a === null) return;
    if (a === -1) sk++;
    else if (a === s.qs[i].ans) c++;
    else w++;
  });
  document.getElementById('cs-sc-correct').textContent = c;
  document.getElementById('cs-sc-wrong').textContent = w;
  document.getElementById('cs-sc-skip').textContent = sk;

  // Options HTML
  let optsHtml = '';
  q.opts.forEach((opt, i) => {
    let style = 'background:var(--surface2);border:1.5px solid var(--border);color:var(--text2);';
    let icon = '';
    if (revealed) {
      if (i === q.ans) { style = 'background:rgba(67,217,142,.15);border:1.5px solid var(--green);color:var(--green);font-weight:700;'; icon = ' ✅'; }
      else if (i === sel) { style = 'background:rgba(240,71,71,.15);border:1.5px solid var(--red);color:var(--red);'; icon = ' ❌'; }
    }
    const clickable = revealed ? '' : `onclick="csSelectOpt(${i})" style="${style}cursor:pointer;"`;
    const staticStyle = revealed ? `style="${style}"` : '';
    optsHtml += `<div class="cs-opt" ${revealed ? staticStyle : `onclick="csSelectOpt(${i})" style="${style}cursor:pointer;"`}
      style="${style}${revealed?'':'cursor:pointer;'}" 
      onclick="${revealed ? '' : 'csSelectOpt('+i+')'}"
      data-i="${i}"
      onmouseover="${revealed ? '' : "this.style.borderColor='var(--accent2)'"}" 
      onmouseout="${revealed ? '' : "this.style.borderColor='var(--border)'"}">
      <span style="font-weight:800;font-family:var(--mono);margin-right:6px">${String.fromCharCode(65+i)}.</span>${opt}${icon}
    </div>`;
  });

  // Explanation (if answered)
  let expHtml = '';
  if (revealed && sel !== -1) {
    expHtml = `<div style="margin-top:10px;background:rgba(88,101,242,.08);border:1px solid rgba(88,101,242,.2);border-radius:8px;padding:10px 12px;font-size:11px;color:var(--text2);line-height:1.6">
      <span style="font-weight:800;color:var(--accent);font-family:var(--mono)">💡 EXPLANATION: </span>${q.exp}
    </div>`;
  }

  // Nav hint
  const isLast = cs.qIdx === total - 1;
  const allAnswered = cs.answers.every(a => a !== null);
  document.getElementById('cs-next-btn').textContent = (isLast && allAnswered) ? 'See Results →' : 'Next →';

  document.getElementById('cs-mcq-area').innerHTML = `
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px">
      <div style="font-size:9px;color:var(--text3);font-family:var(--mono);margin-bottom:8px">Q${cs.qIdx+1} of ${total}</div>
      <div style="font-size:13px;font-weight:600;color:var(--text);line-height:1.6;margin-bottom:14px">${q.q}</div>
      <div style="display:flex;flex-direction:column;gap:8px">${optsHtml}</div>
      ${expHtml}
    </div>`;

  // Fix onclick - re-attach after innerHTML (avoid inline eval issues)
  if (!revealed) {
    document.querySelectorAll('#cs-mcq-area .cs-opt').forEach(el => {
      const i = parseInt(el.getAttribute('data-i'));
      el.onclick = () => csSelectOpt(i);
      el.onmouseover = () => { el.style.borderColor = 'var(--accent2)'; };
      el.onmouseout = () => { el.style.borderColor = 'var(--border)'; };
    });
  }
}

// ─── ANSWER SELECTION ────────────────────────────────────────
function csSelectOpt(i) {
  if (cs.answers[cs.qIdx] !== null) return; // already answered
  cs.answers[cs.qIdx] = i;
  renderCsQ();
}

function csSkip() {
  if (cs.answers[cs.qIdx] === null) {
    cs.answers[cs.qIdx] = -1; // -1 = skipped
  }
  csNext();
}

function csNext() {
  const s = CASE_SCENARIOS[cs.scenarioIdx];
  const total = s.qs.length;
  const allAnswered = cs.answers.every(a => a !== null);

  if (cs.qIdx < total - 1) {
    cs.qIdx++;
    renderCsQ();
  } else if (allAnswered) {
    showCsResults();
  } else {
    // Find first unanswered
    const unanswered = cs.answers.findIndex(a => a === null);
    if (unanswered !== -1) {
      cs.qIdx = unanswered;
      renderCsQ();
    } else {
      showCsResults();
    }
  }
}

function csPrev() {
  if (cs.qIdx > 0) {
    cs.qIdx--;
    renderCsQ();
  }
}

// ─── RESULTS ─────────────────────────────────────────────────
function showCsResults() {
  const s = CASE_SCENARIOS[cs.scenarioIdx];
  let c=0, w=0, sk=0;
  cs.answers.forEach((a, i) => {
    if (a === null || a === -1) sk++;
    else if (a === s.qs[i].ans) c++;
    else w++;
  });
  const total = s.qs.length;
  const pct = total > 0 ? Math.round(c/total*100) : 0;
  // Store score
  cs.scores[s.num] = {c, w, s:sk};

  const grade = pct >= 80 ? '🥇 Excellent' : pct >= 60 ? '🥈 Good' : pct >= 40 ? '🥉 Keep Practicing' : '📚 Revise Concepts';
  const gradeColor = pct >= 60 ? 'var(--green)' : pct >= 40 ? 'var(--gold)' : 'var(--red)';

  // Build review HTML
  let reviewHtml = '';
  s.qs.forEach((q, i) => {
    const a = cs.answers[i];
    const skipped = (a === null || a === -1);
    const correct = !skipped && a === q.ans;
    const color = skipped ? 'var(--text3)' : correct ? 'var(--green)' : 'var(--red)';
    const icon = skipped ? '⏭' : correct ? '✅' : '❌';
    reviewHtml += `<div style="background:var(--bg2);border-radius:8px;padding:10px 12px;margin-bottom:8px;border-left:3px solid ${color}">
      <div style="font-size:9px;font-weight:800;color:${color};font-family:var(--mono);margin-bottom:4px">${icon} Q${i+1}</div>
      <div style="font-size:11px;font-weight:600;margin-bottom:6px">${q.q}</div>
      ${!skipped ? `<div style="font-size:10px;color:${correct?'var(--green)':'var(--red)'}">${correct?'✅':'❌'} Your answer: (${String.fromCharCode(65+a)}) ${q.opts[a]}</div>` : '<div style="font-size:10px;color:var(--text3)">Skipped</div>'}
      ${!correct ? `<div style="font-size:10px;color:var(--green)">✅ Correct: (${String.fromCharCode(65+q.ans)}) ${q.opts[q.ans]}</div>` : ''}
      <div style="font-size:10px;color:var(--text2);background:var(--surface2);border-radius:6px;padding:6px 8px;margin-top:6px">${q.exp}</div>
    </div>`;
  });

  document.getElementById('cs-results').style.display = 'block';
  document.getElementById('cs-results').innerHTML = `
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center">
      <div style="font-size:36px;font-weight:900;color:${gradeColor};font-family:var(--mono);margin-bottom:4px">${pct}%</div>
      <div style="font-size:14px;font-weight:700;margin-bottom:16px">${grade}</div>
      <div style="display:flex;justify-content:center;gap:16px;margin-bottom:20px">
        <div><div style="font-size:22px;font-weight:800;color:var(--green)">${c}</div><div style="font-size:9px;color:var(--text3);font-family:var(--mono)">CORRECT</div></div>
        <div><div style="font-size:22px;font-weight:800;color:var(--red)">${w}</div><div style="font-size:9px;color:var(--text3);font-family:var(--mono)">WRONG</div></div>
        <div><div style="font-size:22px;font-weight:800;color:var(--text3)">${sk}</div><div style="font-size:9px;color:var(--text3);font-family:var(--mono)">SKIPPED</div></div>
      </div>
      <div style="text-align:left;margin-bottom:16px">${reviewHtml}</div>
      <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap">
        <button class="ctrl-btn primary" onclick="retryScenario()">🔄 Retry</button>
        <button class="ctrl-btn" onclick="showCsList()">← All Scenarios</button>
      </div>
    </div>`;

  // Scroll to results
  document.getElementById('cs-results').scrollIntoView({behavior:'smooth'});
  renderCsGrid();
}

function retryScenario() {
  const s = CASE_SCENARIOS[cs.scenarioIdx];
  cs.qIdx = 0;
  cs.answers = new Array(s.qs.length).fill(null);
  document.getElementById('cs-results').style.display = 'none';
  renderCsQ();
  window.scrollTo({top:0,behavior:'smooth'});
}

// ═══ START ═══
init();

</script>
</body>
</html>
