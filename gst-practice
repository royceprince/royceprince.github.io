// ═══════════════════════════════════════════════════════════
// APP STATE
// ═══════════════════════════════════════════════════════════
let state = {
  mode: 'practice',
  chapter: 'ALL',
  category: 'ALL',
  filtered: [],
  index: 0,
  flipped: false,
  correct: 0,
  wrong: 0,
  skip: 0,
  attempted: new Set(),
  // Exam
  examQ: [],
  examIndex: 0,
  examAnswers: [],
  examTimer: null,
  examDuration: 0,
  examTimeLeft: 0,
  examResults: null,
  // Per-session results history
  history: [],
};

// ═══════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════
function init() {
  applyFilters();
  renderCard();
  updateProgress();
  updateScoreBar();
}

// ═══════════════════════════════════════════════════════════
// FILTERING
// ═══════════════════════════════════════════════════════════
function applyFilters() {
  state.filtered = QUESTIONS.filter(q => {
    const chMatch = state.chapter === 'ALL' || q.ch === state.chapter;
    const catMatch = state.category === 'ALL' || q.cat === state.category;
    return chMatch && catMatch;
  });
  state.index = 0;
  state.flipped = false;
}

function filterChapter(ch) {
  state.chapter = ch;
  document.querySelectorAll('.ch-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  applyFilters();
  renderCard();
  updateProgress();
}

function filterCat(cat) {
  state.category = cat;
  document.querySelectorAll('.pill').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  applyFilters();
  renderCard();
  updateProgress();
}

// ═══════════════════════════════════════════════════════════
// CARD RENDERING
// ═══════════════════════════════════════════════════════════
function renderCard() {
  const q = state.filtered[state.index];
  if (!q) {
    document.getElementById('card-front').innerHTML = `<div class="card-loader">No questions match this filter. Try a different selection.</div>`;
    document.getElementById('card-back').innerHTML = '';
    return;
  }

  const diffColor = q.diff === 'Easy' ? 'var(--green)' : q.diff === 'Medium' ? 'var(--gold)' : 'var(--red)';
  const catColors = {CONCEPT:'var(--accent)',MCQ:'var(--green)',CASE:'var(--orange)',TRAP:'var(--red)',PYQ:'var(--purple)',RTP:'var(--cyan)',MTP:'var(--gold)',HARD:'var(--pink)',HARD2:'var(--pink)'};
  const catColor = catColors[q.cat] || 'var(--text3)';
  const catLabels = {CONCEPT:'💡 CONCEPT',MCQ:'✅ MCQ',CASE:'📋 CASE',TRAP:'⚠️ TRAP',PYQ:'🏛 PYQ',RTP:'📘 RTP',MTP:'📝 MTP',HARD:'🔥 POWERAI'};

  // Build options HTML
  let optsHTML = '';
  q.opts.forEach((opt, i) => {
    optsHTML += `<div class="card-option" id="opt-${i}" onclick="selectOption(${i}, ${q.ans}, event)">(${String.fromCharCode(65+i)}) ${opt}</div>`;
  });

  document.getElementById('card-front').innerHTML = `
    <div class="card-header">
      <span class="card-type" style="background:${catColor}22;color:${catColor};border:1px solid ${catColor}44">${catLabels[q.cat]||q.cat}</span>
      <span class="card-diff" style="background:${diffColor}22;color:${diffColor};border:1px solid ${diffColor}44">🎯 ${q.diff}</span>
    </div>
    <div class="card-body">
      <div class="card-q">${q.q}</div>
      <div class="card-options">${optsHTML}</div>
    </div>
    <div class="card-hint">Click an option or flip card for answer</div>
  `;

  document.getElementById('card-back').innerHTML = `
    <div class="card-header">
      <span class="card-type" style="background:rgba(67,217,142,.15);color:var(--green);border:1px solid rgba(67,217,142,.3)">✅ ANSWER</span>
      <span class="card-diff" style="background:${diffColor}22;color:${diffColor};border:1px solid ${diffColor}44">${q.diff}</span>
    </div>
    <div class="card-body">
      <div class="card-ans-label">CORRECT ANSWER</div>
      <div class="card-ans">(${String.fromCharCode(65+q.ans)}) ${q.opts[q.ans]}</div>
      <div class="card-exp">${q.exp}</div>
      ${q.trap ? `<div class="card-trap">⚠️ TRAP NOTE: ${q.trap}</div>` : ''}
      <div class="card-law">📖 Legal Ref: ${q.law}</div>
    </div>
  `;

  // Unflip
  document.getElementById('card-wrapper').classList.remove('flipped');
  state.flipped = false;
  document.getElementById('card-counter').textContent = `${state.index+1} / ${state.filtered.length}`;
}

function selectOption(selected, correct, e) {
  e.stopPropagation();
  const opts = document.querySelectorAll('.card-option');
  opts.forEach((o, i) => {
    if (i === correct) o.classList.add('correct');
    else if (i === selected && selected !== correct) o.classList.add('wrong');
  });
  const qId = state.filtered[state.index]?.id;
  if (qId && !state.attempted.has(qId)) {
    state.attempted.add(qId);
    if (selected === correct) { state.correct++; showNotif('✅ Correct!', 'green'); }
    else { state.wrong++; showNotif('❌ Wrong — check answer', 'red'); }
    updateScoreBar();
  }
}

function flipCard() {
  state.flipped = !state.flipped;
  document.getElementById('card-wrapper').classList.toggle('flipped', state.flipped);
}

function nextCard() {
  if (state.filtered.length === 0) return;
  state.index = (state.index + 1) % state.filtered.length;
  renderCard();
  updateProgress();
}

function prevCard() {
  if (state.filtered.length === 0) return;
  state.index = (state.index - 1 + state.filtered.length) % state.filtered.length;
  renderCard();
  updateProgress();
}

function shuffleCards() {
  for (let i = state.filtered.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [state.filtered[i], state.filtered[j]] = [state.filtered[j], state.filtered[i]];
  }
  state.index = 0;
  renderCard();
  updateProgress();
  showNotif('🔀 Shuffled!');
}

function markCorrect() {
  const q = state.filtered[state.index];
  if (q && !state.attempted.has(q.id)) {
    state.attempted.add(q.id);
    state.correct++;
    updateScoreBar();
    showNotif('✅ Marked Correct');
  }
  nextCard();
}

function markWrong() {
  const q = state.filtered[state.index];
  if (q && !state.attempted.has(q.id)) {
    state.attempted.add(q.id);
    state.wrong++;
    updateScoreBar();
    showNotif('❌ Marked Wrong');
  }
  nextCard();
}

// ═══════════════════════════════════════════════════════════
// PROGRESS & SCORE
// ═══════════════════════════════════════════════════════════
function updateProgress() {
  const total = state.filtered.length;
  const done = state.index + 1;
  const pct = total ? (done / total * 100) : 0;
  document.getElementById('prog-fill').style.width = pct + '%';
  document.getElementById('prog-text').textContent = `${done} / ${total}`;
}

function updateScoreBar() {
  const total = state.correct + state.wrong;
  const pct = total ? Math.round(state.correct / total * 100) : 0;
  document.getElementById('sc-correct').textContent = state.correct;
  document.getElementById('sc-wrong').textContent = state.wrong;
  document.getElementById('sc-skip').textContent = state.attempted.size - total;
  document.getElementById('sc-pct').textContent = total ? pct + '%' : '-';
  // Update progress page
  document.getElementById('pr-correct').textContent = state.correct;
  document.getElementById('pr-wrong').textContent = state.wrong;
  document.getElementById('pr-total').textContent = total;
  document.getElementById('pr-pct').textContent = total ? pct + '%' : '0%';
}

// ═══════════════════════════════════════════════════════════
// MODE SWITCHING
// ═══════════════════════════════════════════════════════════
function setMode(mode) {
  // Stop exam timer if leaving exam mode
  if (state.mode === 'exam' && mode !== 'exam') {
    clearInterval(state.examTimer);
    state.examTimer = null;
  }
  state.mode = mode;
  document.querySelectorAll('.mode-tab').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.getElementById('sec-' + mode).classList.add('active');
  if (mode === 'results') updateResults();
  if (mode === 'case') renderCsGrid();
}

// ═══════════════════════════════════════════════════════════
// EXAM MODE
// ═══════════════════════════════════════════════════════════
function startExam() {
  // Clear any running timer first (fix timer bug)
  if (state.examTimer) { clearInterval(state.examTimer); state.examTimer = null; }
  
  const numQ = parseInt(document.querySelector('[name=examq]:checked').value);
  const timeMins = numQ === 15 ? 20 : numQ === 30 ? 45 : 75;
  
  // Pick random questions
  const pool = [...QUESTIONS].sort(() => Math.random() - 0.5).slice(0, numQ);
  state.examQ = pool;
  state.examIndex = 0;
  state.examAnswers = new Array(numQ).fill(null);
  state.examDuration = timeMins * 60;
  state.examTimeLeft = timeMins * 60;

  document.getElementById('exam-setup').style.display = 'none';
  document.getElementById('exam-active').style.display = 'block';
  
  renderExamCard();
  startTimer();
}

function renderExamCard() {
  const q = state.examQ[state.examIndex];
  if (!q) return;
  
  document.getElementById('exam-q-counter').textContent = `Q ${state.examIndex+1} / ${state.examQ.length}`;
  
  let optsHTML = '';
  q.opts.forEach((opt, i) => {
    const selected = state.examAnswers[state.examIndex] === i;
    optsHTML += `<div class="card-option${selected ? ' correct' : ''}" style="cursor:pointer" onclick="examSelect(${i})">(${String.fromCharCode(65+i)}) ${opt}</div>`;
  });

  const catColors = {CONCEPT:'var(--accent)',MCQ:'var(--green)',CASE:'var(--orange)',TRAP:'var(--red)',PYQ:'var(--purple)',RTP:'var(--cyan)',MTP:'var(--gold)',HARD:'var(--pink)'};
  const diffColor = q.diff === 'Easy' ? 'var(--green)' : q.diff === 'Medium' ? 'var(--gold)' : 'var(--red)';

  document.getElementById('exam-card-front').innerHTML = `
    <div class="card-header">
      <span class="card-type" style="background:${catColors[q.cat]||'var(--accent)'}22;color:${catColors[q.cat]||'var(--accent)'};border:1px solid ${catColors[q.cat]||'var(--accent)'}44">${q.cat} | ${q.ch}</span>
      <span class="card-diff" style="background:${diffColor}22;color:${diffColor};border:1px solid ${diffColor}44">${q.diff}</span>
    </div>
    <div class="card-body">
      <div class="card-q">${q.q}</div>
      <div class="card-options">${optsHTML}</div>
    </div>
    <div class="card-hint">${state.examIndex+1} of ${state.examQ.length} • Select answer then click Next</div>
  `;
}

function examSelect(i) {
  state.examAnswers[state.examIndex] = i;
  renderExamCard();
}

function examSkip() {
  if (state.examIndex < state.examQ.length - 1) {
    state.examIndex++;
    renderExamCard();
  } else {
    endExam();
  }
}

function endExamEarly() {
  if (confirm('End exam early? Current answers will be scored.')) endExam();
}

function startTimer() {
  clearInterval(state.examTimer);
  state.examTimer = setInterval(() => {
    state.examTimeLeft--;
    updateTimerDisplay();
    if (state.examTimeLeft <= 0) {
      clearInterval(state.examTimer);
      endExam();
    }
  }, 1000);
}

function updateTimerDisplay() {
  const m = Math.floor(state.examTimeLeft / 60);
  const s = state.examTimeLeft % 60;
  const disp = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  document.getElementById('timer-display').textContent = disp;
  const pct = (state.examTimeLeft / state.examDuration) * 100;
  document.getElementById('timer-bar').style.width = pct + '%';
  const timerEl = document.querySelector('.exam-timer');
  if (state.examTimeLeft < 60) { timerEl.classList.add('timer-danger'); document.getElementById('timer-bar').style.background = 'var(--red)'; }
  else if (state.examTimeLeft < 300) document.getElementById('timer-bar').style.background = 'var(--orange)';
}

function endExam() {
  clearInterval(state.examTimer);
  // Calculate results
  let correct = 0, wrong = 0, skip = 0;
  const breakdown = {};
  state.examQ.forEach((q, i) => {
    const ans = state.examAnswers[i];
    if (ans === null) { skip++; }
    else if (ans === q.ans) { correct++; }
    else { wrong++; }
    if (!breakdown[q.ch]) breakdown[q.ch] = {c:0,w:0,s:0};
    if (ans === null) breakdown[q.ch].s++;
    else if (ans === q.ans) breakdown[q.ch].c++;
    else breakdown[q.ch].w++;
  });
  
  const total = state.examQ.length;
  const pct = Math.round((correct / total) * 100);
  const grade = pct >= 80 ? '🥇 Excellent' : pct >= 60 ? '🥈 Good' : pct >= 40 ? '🥉 Average' : '📚 Need More Practice';
  
  state.examResults = {correct, wrong, skip, total, pct, grade, breakdown, timeTaken: state.examDuration - state.examTimeLeft};
  state.history.push(state.examResults);
  
  // Show results in exam section
  document.getElementById('exam-active').style.display = 'none';
  document.getElementById('exam-setup').style.display = 'block';
  document.getElementById('exam-setup').innerHTML = `
    <div class="results-panel" style="margin-top:0">
      <div class="results-score">${pct}%</div>
      <div class="results-grade">${grade}</div>
      <div class="results-stats">
        <div class="results-stat"><div class="results-stat-num" style="color:var(--green)">${correct}</div><div class="results-stat-label">CORRECT</div></div>
        <div class="results-stat"><div class="results-stat-num" style="color:var(--red)">${wrong}</div><div class="results-stat-label">WRONG</div></div>
        <div class="results-stat"><div class="results-stat-num" style="color:var(--text3)">${skip}</div><div class="results-stat-label">SKIPPED</div></div>
        <div class="results-stat"><div class="results-stat-num" style="color:var(--gold)">${Math.floor(state.examResults.timeTaken/60)}m ${state.examResults.timeTaken%60}s</div><div class="results-stat-label">TIME TAKEN</div></div>
      </div>
      <div class="results-breakdown">
        <div style="font-size:11px;font-weight:800;color:var(--accent2);font-family:var(--mono);margin-bottom:8px">CHAPTER-WISE PERFORMANCE</div>
        ${Object.entries(breakdown).map(([ch, d]) => {
          const chTotal = d.c + d.w + d.s;
          const chPct = Math.round((d.c/chTotal)*100);
          return `<div class="rb-row"><span>${ch}</span><span style="color:var(--green)">${d.c}✅</span><span style="color:var(--red)">${d.w}❌</span><span style="color:var(--text3)">${d.s}⏭</span><span style="color:${chPct>=60?'var(--green)':'var(--red)'}">${chPct}%</span></div>`;
        }).join('')}
      </div>
      <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap">
        <button class="ctrl-btn primary" onclick="retryExam()">🔄 Try Again</button>
        <button class="ctrl-btn" onclick="reviewExam()">📖 Review Answers</button>
      </div>
    </div>
  `;
  updateResults();
}

function retryExam() {
  document.getElementById('exam-setup').innerHTML = `
    <div class="results-panel" style="margin-top:0">
      <div style="font-size:28px;margin-bottom:12px">⏱</div>
      <div style="font-size:20px;font-weight:800;margin-bottom:8px">Exam Mode</div>
      <div style="font-size:13px;color:var(--text2);margin-bottom:24px;line-height:1.5">Simulate ICAI exam conditions.<br>30 questions · 45 minutes · MCQ format</div>
      <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin-bottom:20px">
        <label style="font-size:12px;color:var(--text2);display:flex;align-items:center;gap:6px;cursor:pointer;font-family:var(--mono)"><input type="radio" name="examq" value="15"> Quick (15Q / 20min)</label>
        <label style="font-size:12px;color:var(--text2);display:flex;align-items:center;gap:6px;cursor:pointer;font-family:var(--mono)"><input type="radio" name="examq" value="30" checked> Standard (30Q / 45min)</label>
        <label style="font-size:12px;color:var(--text2);display:flex;align-items:center;gap:6px;cursor:pointer;font-family:var(--mono)"><input type="radio" name="examq" value="50"> Full Mock (50Q / 75min)</label>
      </div>
      <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap">
        <button class="ctrl-btn primary" onclick="startExam()" style="font-size:13px;padding:11px 24px">Start Exam →</button>
      </div>
    </div>
  `;
}

function reviewExam() {
  if (!state.examResults) return;
  let html = `<div class="results-panel" style="margin-top:0;text-align:left">
    <div style="font-size:16px;font-weight:800;margin-bottom:16px;text-align:center">📖 Answer Review</div>`;
  
  state.examQ.forEach((q, i) => {
    const ans = state.examAnswers[i];
    const correct = ans === q.ans;
    const skipped = ans === null;
    const color = skipped ? 'var(--text3)' : correct ? 'var(--green)' : 'var(--red)';
    const icon = skipped ? '⏭' : correct ? '✅' : '❌';
    html += `<div style="background:var(--bg2);border-radius:10px;padding:12px;margin-bottom:10px;border-left:3px solid ${color}">
      <div style="font-size:10px;font-weight:800;color:${color};font-family:var(--mono);margin-bottom:6px">${icon} Q${i+1} · ${q.ch} · ${q.cat} · ${q.diff}</div>
      <div style="font-size:12px;font-weight:600;margin-bottom:8px">${q.q}</div>
      ${ans !== null ? `<div style="font-size:11px;color:${correct?'var(--green)':'var(--red)'};margin-bottom:4px">Your Answer: (${String.fromCharCode(65+ans)}) ${q.opts[ans]}</div>` : '<div style="font-size:11px;color:var(--text3);margin-bottom:4px">Skipped</div>'}
      ${!correct ? `<div style="font-size:11px;color:var(--green);margin-bottom:4px">Correct: (${String.fromCharCode(65+q.ans)}) ${q.opts[q.ans]}</div>` : ''}
      <div style="font-size:10px;color:var(--text2);background:var(--surface2);border-radius:6px;padding:6px 8px;margin-top:6px">${q.exp}</div>
    </div>`;
  });
  html += `<button class="ctrl-btn primary" style="width:100%;margin-top:8px" onclick="retryExam()">🔄 Try Again</button></div>`;
  
  document.getElementById('exam-setup').innerHTML = html;
}

// ═══════════════════════════════════════════════════════════
// RESULTS PAGE
// ═══════════════════════════════════════════════════════════
function updateResults() {
  const last = state.history[state.history.length - 1];
  if (!last) return;
  document.getElementById('pr-correct').textContent = last.correct;
  document.getElementById('pr-wrong').textContent = last.wrong;
  document.getElementById('pr-total').textContent = last.total;
  document.getElementById('pr-pct').textContent = last.pct + '%';
  
  let breakdownHTML = '';
  Object.entries(last.breakdown || {}).forEach(([ch, d]) => {
    const t = d.c + d.w + d.s;
    const p = Math.round((d.c/t)*100);
    breakdownHTML += `<div class="rb-row"><span>${ch}</span><span style="color:var(--green)">${d.c}✅</span><span style="color:var(--red)">${d.w}❌</span><span style="color:${p>=60?'var(--green)':'var(--red)'}">${p}%</span></div>`;
  });
  document.getElementById('pr-breakdown').innerHTML = breakdownHTML || '<div style="text-align:center;color:var(--text3);font-size:11px;font-family:var(--mono)">Complete an exam to see chapter breakdown</div>';
}

function resetProgress() {
  state.correct = 0; state.wrong = 0; state.skip = 0;
  state.attempted = new Set();
  state.history = [];
  updateScoreBar();
  updateResults();
  showNotif('🔄 Progress Reset');
}

// ═══════════════════════════════════════════════════════════
// UI HELPERS
// ═══════════════════════════════════════════════════════════
function toggleDark() {
  document.body.classList.toggle('light');
  document.getElementById('darkBtn').textContent = document.body.classList.contains('light') ? '🌙' : '☀️';
}

function showNotif(msg, type) {
  const n = document.getElementById('notif');
  n.textContent = msg;
  n.style.borderColor = type === 'green' ? 'var(--green)' : type === 'red' ? 'var(--red)' : 'var(--border2)';
  n.classList.add('show');
  setTimeout(() => n.classList.remove('show'), 2000);
}

// Keyboard navigation
document.addEventListener('keydown', e => {
  if (state.mode !== 'practice') return;
  if (e.key === 'ArrowRight') nextCard();
  else if (e.key === 'ArrowLeft') prevCard();
  else if (e.key === ' ') { e.preventDefault(); flipCard(); }
});


